{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    /* Strict Inheritance */
    "strict": true,

    /* Path Aliases */
    "paths": {
      "@/*": ["./src/*"]
    },

    /* Code Quality & Security */
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "noImplicitAny": true,
    "exactOptionalPropertyTypes": false, // Note: Can give problems with some React-Native libraries, activate only if necessary.

    "allowUnreachableCode": false,

    "noFallthroughCasesInSwitch": true,

    /* Type Rigor */
    "noImplicitOverride": true,
    "noPropertyAccessFromIndexSignature": true,

    /* Robustness in the environment */
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,

    /* Expo Router Integration */
    "moduleResolution": "bundler",
    "plugins": [
      {
        "name": "expo-router"
      }
    ]
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts",
    "src/app/**/*.ts",
    "src/app/**/*.tsx"
  ]
}
